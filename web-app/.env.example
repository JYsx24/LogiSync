# Firebase project config — copy to .env and fill in values from Firebase Console
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Error tracking — sign up at https://sentry.io (free tier), create a React project,
# and paste the DSN here. Leave blank to disable Sentry.
VITE_SENTRY_DSN=

# Set to "true" to point Firebase SDK at local emulators (firebase emulators:start)
VITE_USE_EMULATORS=false
