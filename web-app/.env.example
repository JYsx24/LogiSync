# Firebase configuration
# 1. Go to https://console.firebase.google.com
# 2. Select your project → Project Settings → Your apps → SDK setup & configuration
# 3. Copy the values below into a new file called .env in this directory (web-app/.env)

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Error tracking (optional)
# Sign up at https://sentry.io (free tier) → create a React project → paste the DSN here.
# Leave blank to disable Sentry.
VITE_SENTRY_DSN=

# Local emulators (optional)
# Set to "true" to point the Firebase SDK at local emulators (firebase emulators:start).
VITE_USE_EMULATORS=false
