rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Photos are stored under the uploading user's uid — only that user can write/delete,
    // but any authenticated user can read (needed if photos are ever shared).
    match /photos/{userId}/{fileName} {
      allow read:   if request.auth != null;
      allow write:  if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.size < 10 * 1024 * 1024  // 10 MB cap
                    && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
